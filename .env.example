# Copy this file to .env and fill in your own values.
# Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — only needed if you want rejection emails sent automatically.
# Leave blank to rely on the in-app "sent back for correction" notice only.
# EmailJS: emailjs.com -> Email Services / Email Templates / Account -> Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
